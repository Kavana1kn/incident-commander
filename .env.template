# Incident Commander — .env template
# Copy this file to `.env` and paste your keys. NEVER commit the real .env (it is git-ignored).

# --- Neuro SAN server / UI ---
NEURO_SAN_SERVER_HOST="localhost"
NEURO_SAN_SERVER_CONNECTION="http"
NEURO_SAN_SERVER_HTTP_PORT=8080
NSFLOW_HOST="localhost"
NSFLOW_PORT=4173
AGENT_SERVICE_LOG_JSON=logging.hocon

# Thinking-file path. Windows example below; on macOS/Linux use e.g. /tmp/agent_thinking.txt
THINKING_FILE="C:\\tmp\\agent_thinking.txt"

# =====================================================================
# LLM PROVIDER KEYS — set the one you will use. neuro-san picks the first
# provider (per config/developer_llm_config.hocon) whose key is present.
# =====================================================================

# PRIMARY on a personal (non-Zscaler) network. Mistral is blocked by Cognizant's proxy.
MISTRAL_API_KEY="PASTE_YOUR_MISTRAL_KEY_HERE"

# Reachable everywhere; free tier ~20 req/day for gemini-2.5-flash. Set BOTH names.
GEMINI_API_KEY="PASTE_YOUR_GEMINI_KEY_HERE"
GOOGLE_API_KEY="PASTE_YOUR_GEMINI_KEY_HERE"

# Optional: reachable even on the corporate network. Set if you have one.
# ANTHROPIC_API_KEY="PASTE_YOUR_ANTHROPIC_KEY_HERE"

# --- Optional: real Slack delivery for CommsDispatcher (demo works without it) ---
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXXX/YYYY/ZZZZ"

# --- Observability (optional; off by default) ---
LOGBRIDGE_ENABLED=true
PHOENIX_ENABLED=false
LANGFUSE_ENABLED=false
